# Copy to .env and fill in. Get these from your watsonx.ai project.
WATSONX_APIKEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct
EMBED_MODEL_ID=ibm/slate-125m-english-rtrvr-v2

# MOCK=1 runs everything offline with fake models (no watsonx creds needed).
MOCK=0
# RAG=0 skips Docling ingestion at startup (faster boot, no document grounding).
RAG=1
